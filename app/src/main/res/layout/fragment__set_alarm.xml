<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragment_SetAlarm"
    android:background="@color/black"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <Space
            android:layout_width="wrap_content"
            android:layout_height="10dp"
            ></Space>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="right"
            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set Alarm"
                android:textColor="@color/white"
                ></TextView>

        </LinearLayout><!--Finish linear layour TextView-->

    <Space
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        ></Space>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            >

            <EditText
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50"
                android:textSize="100dp"
                android:textColor="@color/white"
                android:hint="0"
                android:layout_marginStart="20dp"
                ></EditText>

            <Space
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                ></Space>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <FrameLayout
                    android:id="@+id/ID_ButtonSave"
                    android:layout_width="150dp"
                    android:layout_height="50dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="10dp"
                    android:layout_weight="0.33"
                    >

                    <ImageView
                        android:id="@+id/ID_ButtonImageSave"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/disable"
                        android:scaleType="centerCrop"></ImageView>

                    <TextView
                        android:id="@+id/ID_ButtonTextSave"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="Save"
                        android:textSize="20dp"
                        android:textColor="@color/white"
                        android:textStyle="bold"></TextView>

                </FrameLayout><!-- Finish create new image button -->
                <FrameLayout
                    android:id="@+id/ID_ButtonOverWrite"
                    android:layout_width="150dp"
                    android:layout_height="50dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="10dp"
                    android:layout_weight="0.33"
                    >

                    <ImageView
                        android:id="@+id/ID_ButtonImageOverWrite"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/disable"
                        android:scaleType="centerCrop"></ImageView>

                    <TextView
                        android:id="@+id/ID_ButtonTextOverWrite"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="Overwrite"
                        android:textSize="20dp"
                        android:textColor="@color/white"
                        android:textStyle="bold"></TextView>

                </FrameLayout><!-- Finish create new image button -->
                <FrameLayout
                    android:id="@+id/ID_ButtonAbort"
                    android:layout_width="150dp"
                    android:layout_height="50dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="10dp"
                    android:layout_weight="0.33"
                    >

                    <ImageView
                        android:id="@+id/ID_ButtonImageAbort"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/disable"
                        android:scaleType="centerCrop"></ImageView>

                    <TextView
                        android:id="@+id/ID_ButtonTextAbort"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="Abort"
                        android:textSize="20dp"
                        android:textColor="@color/white"
                        android:textStyle="bold"></TextView>

                </FrameLayout><!-- Finish create new image button -->



            </LinearLayout>





        </LinearLayout>



    </LinearLayout>

        <Space
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            ></Space>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="10dp"
            >

            <CheckBox
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleX="1"
                android:scaleY="1.5"
                android:text="Moday"
                android:textColor="@color/white"></CheckBox>

            <CheckBox
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleX="1"
                android:scaleY="1.5"
                android:text="Tuesday"
                android:textColor="@color/white"></CheckBox>

            <CheckBox
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleX="1"
                android:scaleY="1.5"
                android:text="Wednesday"
                android:textColor="@color/white"></CheckBox>

            <CheckBox
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleX="1"
                android:scaleY="1.5"
                android:text="Thursday"
                android:textColor="@color/white"></CheckBox>

            <CheckBox
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleX="1"
                android:scaleY="1.5"
                android:text="Friday"
                android:textColor="@color/white"></CheckBox>
            <CheckBox
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleX="1"
                android:scaleY="1.5"
                android:text="Saturday"
                android:textColor="@color/white"></CheckBox>
            <CheckBox
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleX="1"
                android:scaleY="1.5"
                android:text="Friday"
                android:textColor="@color/white"></CheckBox>






        </LinearLayout>



    </LinearLayout>

</FrameLayout>