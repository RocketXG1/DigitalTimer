<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FRAGMENT_MONITORING"
    android:background="@color/black"
    >


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

    <Space
        android:layout_width="wrap_content"
        android:layout_height="10dp"
        ></Space>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="right"

        >
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Monitoring mode"
        android:textColor="@color/white"
        ></TextView>

    </LinearLayout><!--Finish linear layour TextView-->
        <!--__________________Start to add new Elements_____________________-->

        <Space
            android:layout_width="wrap_content"
            android:layout_height="10dp"

            ></Space>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"

            >

            <TextView
                android:id="@+id/ID_PhoneDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:text="28 October 2025"></TextView>

            <TextView
                android:id="@+id/ID_PhoneDay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="25dp"
                android:textColor="@color/white"
                android:text="Wensday"></TextView>

            <Space
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                ></Space>

            <FrameLayout
                android:id="@+id/ID_ButtonFrameSync"
                android:layout_width="300dp"
                android:layout_height="80dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_gravity="center_horizontal">

                <ImageView
                    android:id="@+id/ID_ButtonImageSync"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/disable"
                    android:scaleType="centerCrop"></ImageView>

                <TextView
                    android:id="@+id/ID_ButtonTextSync"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Sync device"
                    android:textSize="20dp"
                    android:textColor="@color/black"
                    android:textStyle="bold"></TextView>

            </FrameLayout><!-- Finish create new image button -->
            <Space
                android:layout_width="wrap_content"
                android:layout_height="40dp"></Space>

            <FrameLayout
                android:id="@+id/ID_ButtonFrameTime"
                android:layout_width="300dp"
                android:layout_height="80dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_gravity="center_horizontal">

                <ImageView
                    android:id="@+id/ID_ButtonImageTime"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/disable"
                    android:scaleType="centerCrop"></ImageView>

                <TextView
                    android:id="@+id/ID_ButtonTextTime"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Sync device"
                    android:textSize="20dp"
                    android:textColor="@color/black"
                    android:textStyle="bold"></TextView>

            </FrameLayout><!-- Finish create new image button -->
            <Space
                android:layout_width="wrap_content"
                android:layout_height="20dp"></Space>

            <CheckBox
                android:id="@+id/ID_Persistent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Persistent"
                android:textColor="@color/white"
                android:textSize="20dp"
                android:scaleX="1.5"
                android:scaleY="1.5"
                android:buttonTint="@color/chekcbox_selector"
                ></CheckBox>

            <Space
                android:layout_width="wrap_content"
                android:layout_height="20dp"></Space>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="20dp"
                >

                <TextView
                    android:id="@+id/ID_FixMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18dp"
                    android:textColor="@color/white"
                    android:text="Date and time on Device"></TextView>

                <TextView
                    android:id="@+id/ID_DeviceDay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="25dp"
                    android:textColor="@color/white"
                    android:text="Wensday 28 of"></TextView>

                <TextView
                    android:id="@+id/ID_DeviceDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="40dp"
                    android:textColor="@color/white"
                    android:text="October 2025"></TextView>

                <TextView
                    android:id="@+id/ID_DeviceTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="25dp"
                    android:textColor="@color/white"
                    android:text="21:33:55"></TextView>

            </LinearLayout>







        </LinearLayout> <!--Layour for buttons-->


        <!--__________________Finish to add new Elements_____________________-->

    </LinearLayout><!--Finish main linear layour-->





</FrameLayout>